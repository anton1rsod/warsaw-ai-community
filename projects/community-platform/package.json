{
  "name": "@warsaw-ai/community-platform",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps",
    "prepare": "cd ../.. && git config core.hooksPath projects/community-platform/.husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm exec eslint --fix"
    ]
  },
  "dependencies": {
    "next": "15.0.4",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.0.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "typescript": "5.7.2",
    "typescript-eslint": "^8.59.1"
  }
}
