{
  "name": "@warsaw-ai/community-platform",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "snapshot": "tsx scripts/snapshot-content.ts",
    "predev": "pnpm snapshot",
    "dev": "next dev",
    "prebuild": "pnpm snapshot",
    "build": "next build",
    "start": "next start",
    "prelint": "pnpm snapshot",
    "lint": "eslint .",
    "pretypecheck": "pnpm snapshot",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm snapshot",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:coverage": "pnpm snapshot",
    "test:coverage": "vitest run --coverage",
    "pree2e": "pnpm snapshot",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps",
    "prepare": "cd ../.. && git config core.hooksPath projects/community-platform/.husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm exec eslint --fix"
    ]
  },
  "dependencies": {
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "22.10.2",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "5.7.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.9"
  }
}
